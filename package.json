{
  "name": "knowledgeos",
  "version": "1.0.0",
  "description": "KnowledgeOS — Your Personal AI Learning Operating System",
  "private": true,
  "scripts": {
    "dev:server": "cd backend && python3 -m uvicorn app.main:app --reload --port 3001",
    "dev:client": "npm run dev --prefix frontend",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "build:client": "npm run build --prefix frontend",
    "install:all": "npm install --prefix frontend && cd backend && pip install -r requirements.txt",
    "install:server:py": "cd backend && pip install -r requirements.txt"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
