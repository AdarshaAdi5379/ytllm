OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# Optional: set if using OpenRouter or other OpenAI-compatible endpoint
# OPENAI_BASE_URL=https://openrouter.ai/api/v1

PORT=3001
NODE_ENV=development
CORS_ORIGINS=http://localhost:5173,http://localhost:5174

# Auth (Legacy — kept for backward compatibility)
JWT_SECRET=generate-a-random-secret-key-here

# Database — PostgreSQL (required)
# Local development (adjust port/host as needed):
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/knowledgeos
# Production (Supabase):
# DATABASE_URL=postgresql+asyncpg://postgres:YOUR_PASSWORD@db.your-project.supabase.co:5432/postgres

# Supabase Auth — set these to start using Supabase as identity provider
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# SUPABASE_JWT_SECRET=your-jwt-secret-from-supabase-settings

# Error tracking (optional)
# SENTRY_DSN=https://your-dsn@sentry.io/your-project

# Logging (optional)
# LOG_LEVEL=DEBUG
# JSON_LOGS=true

# Vector storage (persistence for ChromaDB indexes)
# VECTOR_STORAGE_PATH=./data/vectors

# Whisper fallback — auto-transcribe videos without captions via OpenAI Whisper API
# Set to false to skip audio download + transcription for no-caption videos
# ENABLE_WHISPER_FALLBACK=true
# WHISPER_MODEL=whisper-1
