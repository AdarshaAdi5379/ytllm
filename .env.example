# YouTube AI Chat Agent — Environment Variables

# Copy this file to `.env` and fill in your values.

# ─── Required ───────────────────────────────────────────────
# Google API key from Google AI Studio (https://aistudio.google.com)
# Must have YouTube Data API v3, Gemini 1.5 Flash, and text-embedding-004 enabled
GOOGLE_API_KEY=your_google_api_key_here

# ─── Optional (defaults shown) ──────────────────────────────
PORT=3001
NODE_ENV=development
# URL of the React frontend — used for CORS allow-list
CORS_ORIGIN=http://localhost:5173
