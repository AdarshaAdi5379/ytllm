# YouTube AI Chat Agent — Environment Variables

# Copy this file to `.env` and fill in your values.

# ─── Required ───────────────────────────────────────────────
# Google API key from Google AI Studio (https://aistudio.google.com)
# Must have YouTube Data API v3, Gemini 1.5 Flash, and text-embedding-004 enabled
GOOGLE_API_KEY=your_google_api_key_here

# ─── Optional (defaults shown) ──────────────────────────────
PORT=3001
NODE_ENV=development
# Comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:5173,http://localhost:5174

# Session/vector cleanup
# SESSION_CACHE_TTL=7200
# CLEANUP_INTERVAL_S=600
# VECTOR_INDEX_TTL_S=7200

# Multi-video chat
# MAX_MULTI_VIDEOS=10
